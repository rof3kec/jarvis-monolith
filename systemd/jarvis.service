[Unit]
Description=Jarvis Fast Monolith (Ctrl+Space)
After=network.target ydotoold.service

[Service]
Type=simple
# Must use the uv virtual environment Python inside the new repo
ExecStart=/home/mchang/repos/jarvis-monolith/.venv/bin/python /home/mchang/repos/jarvis-monolith/jarvis.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
